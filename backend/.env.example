# How often (hours) to re-fetch every novel's table of contents to pick up new
# chapters of ongoing serials. 0 disables the scheduler. Default 6.
REFRESH_INTERVAL_HOURS=6

# Optional, only needed for the "import favorites" feature. Log into
# https://syosetu.org/?mode=login yourself in a real browser (never automate
# this), then copy the resulting session cookies (name=value; name=value) -
# typically the "autologin" and "sson" cookies for syosetu.org. Never commit
# this file or paste real values into chat/issues/PRs.
HAMELN_COOKIE=
